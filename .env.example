OPENROUTER_API_KEY=your_openrouter_api_key
OPENAI_API_BASE=https://openrouter.ai/api/v1
OPENAI_MODEL_NAME=openrouter/meta-llama/llama-3.2-3b-instruct:free

# Optional: comma-separated fallbacks used automatically if the primary model
# is missing/unavailable or rate-limited.
# Example:
# OPENAI_MODEL_FALLBACKS=openrouter/mistralai/mistral-7b-instruct,openrouter/qwen/qwen-2.5-7b-instruct
# OPENAI_MODEL_FALLBACKS=

# Optional: limit cycles per run (default: unlimited)
# MAX_CYCLES_PER_RUN=5

# Optional: seconds between cycles (default: 60)
# CYCLE_DELAY_SECONDS=60
