{
  "feedback": {
    "type": "object",
    "properties": {
      "userId": {
        "type": "string",
        "description": "Unique identifier for the user"
      },
      "lessonId": {
        "type": "string",
        "description": "Identifier for the lesson being reviewed"
      },
      "rating": {
        "type": "integer",
        "description": "Rating given by the user (1-5)"
      },
      "comments": {
        "type": "string",
        "description": "User comments about the lesson"
      }
    },
    "required": ["userId", "lessonId", "rating"]
  }
}