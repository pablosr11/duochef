{\n  "lesson_title": "Slicing Techniques",\n  "steps": [\n    {\n      "instruction": "Gather your ingredients and tools.",\n      "duration": 30\n    },\n    {\n      "instruction": "Learn the basic grip for holding a knife.",\n      "duration": 60\n    },\n    {\n      "instruction": "Practice slicing an onion into thin pieces.",\n      "duration": 120\n    },\n    {\n      "instruction": "Practice slicing a bell pepper into strips.",\n      "duration": 120\n    },\n    {\n      "instruction": "Review your technique and clean your workspace.",\n      "duration": 30\n    }\n  ],\n  "safety_tips": [\n    "Always cut away from your body.",\n    "Keep your fingers curled back while slicing.",\n    "Use a stable cutting board."\n  ]\n}