{\n  "level": 6,\n  "title": "Advanced Cooking Skills",\n  "lessons": [\n    {\n      "title": "Making Sauces",\n      "description": "Learn how to create basic sauces like béchamel and marinara.",\n      "steps": [\n        "Gather ingredients: flour, butter, milk, tomatoes, herbs.",\n        "Melt butter and whisk in flour to create a roux.",\n        "Gradually add milk while whisking to avoid lumps.",\n        "Simmer until thickened and season to taste.",\n        "For marinara, sauté garlic and onions, add tomatoes and herbs, simmer for 20 minutes."\n      ]\n    },\n    {\n      "title": "Marinating Techniques",\n      "description": "Understand how to marinate proteins and vegetables for enhanced flavor.",\n      "steps": [\n        "Choose a protein or vegetable to marinate.",\n        "Prepare a marinade using oil, acid (like vinegar or citrus), and seasonings.",\n        "Combine the protein/vegetable with the marinade in a bowl or bag, refrigerate for at least 30 minutes.",\n        "Cook as desired, ensuring to discard any leftover marinade."\n      ]\n    },\n    {\n      "title": "Using Herbs Effectively",\n      "description": "Learn how to select and use fresh herbs in cooking.",\n      "steps": [\n        "Identify common herbs: basil, parsley, cilantro, thyme.",\n        "Learn proper storage methods for freshness.",\n        "Understand when to add herbs during cooking for maximum flavor impact."\n      ]\n    }\n  ]\n}